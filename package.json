{
   "name": "swift-auth-monorepo",
   "type": "module",
   "private": true,
   "scripts": {
      "build": "pnpm -r build",
      "test:e2e": "pnpm --filter swift-auth-cli test:e2e",
      "test": "pnpm -r --sequential test",
      "clean": "pnpm -r exec rimraf dist",
      "lint": "eslint .",
      "lint:fix": "eslint . --fix",
      "format": "prettier \"**/*.{ts,tsx,js,json,md}\" --write",
      "format:check": "prettier \"**/*.{ts,tsx,js,json,md}\" --check",
      "typecheck": "pnpm -r typecheck",
      "changeset": "changeset",
      "version": "changeset version",
      "release": "pnpm build && changeset publish"
   },
   "devDependencies": {
      "@changesets/cli": "^2.31.0",
      "@eslint/js": "^10.0.1",
      "@typescript-eslint/eslint-plugin": "^8.58.0",
      "@typescript-eslint/parser": "^8.58.0",
      "eslint": "^10.1.0",
      "prettier": "^3.8.1",
      "rimraf": "^6.1.3",
      "typescript": "^6.0.2",
      "typescript-eslint": "^8.58.0"
   }
}
