{
   "name": "swift-auth",
   "version": "0.0.1",
   "private": false,
   "type": "module",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test:e2e": "vitest run tests/e2e",
      "test": "vitest run",
      "typecheck": "tsc --noEmit"
   },
   "files": [
      "dist"
   ],
   "devDependencies": {
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   },
   "dependencies": {
      "zod": "^4.3.6"
   }
}
