{
   "name": "@authio/core",
   "version": "0.1.1",
   "description": "Type-safe authentication built for developers who want simplicity, flexibility, and control without hidden abstractions or framework lock-in.",
   "author": "Dipan Chakraborty",
   "license": "MIT",
   "repository": {
      "type": "git",
      "url": "https://github.com/dipan-ck/authio.git"
   },
   "keywords": [
      "auth",
      "authentication",
      "jwt",
      "oauth",
      "authio"
   ],
   "private": false,
   "publishConfig": {
      "access": "public"
   },
   "type": "module",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.cjs"
         }
      },
      "./providers": {
         "import": {
            "types": "./dist/providers/index.d.ts",
            "default": "./dist/providers/index.js"
         },
         "require": {
            "types": "./dist/providers/index.d.ts",
            "default": "./dist/providers/index.cjs"
         }
      }
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test:e2e": "vitest run tests/e2e",
      "test": "vitest run",
      "typecheck": "tsc --noEmit"
   },
   "files": [
      "dist"
   ],
   "devDependencies": {
      "@types/bcryptjs": "^3.0.0",
      "@types/node": "^25.5.0",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   },
   "dependencies": {
      "bcryptjs": "^3.0.3",
      "zod": "^4.4.3"
   }
}
