{
   "name": "@authio/cli",
   "version": "0.1.1",
   "description": "CLI for generating database schemas for Authio",
   "author": "Dipan Chakraborty",
   "repository": {
      "type": "git",
      "url": "https://github.com/dipan-ck/authio.git"
   },
   "keywords": [
      "auth",
      "authentication",
      "jwt",
      "oauth",
      "authio"
   ],
   "publishConfig": {
      "access": "public"
   },
   "license": "MIT",
   "private": false,
   "type": "module",
   "bin": {
      "authio": "./dist/index.js"
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test": "vitest run",
      "test:e2e": "vitest run tests/e2e",
      "typecheck": "tsc --noEmit"
   },
   "files": [
      "dist"
   ],
   "dependencies": {
      "citty": "^0.1.0",
      "jiti": "^2.7.0"
   },
   "devDependencies": {
      "@types/node": "^25.5.0",
      "@authio/core": ">=0.1.0",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   }
}
