{
   "name": "@authio/prisma",
   "version": "0.1.1",
   "author": "Dipan Chakraborty",
   "repository": {
      "type": "git",
      "url": "https://github.com/dipan-ck/authio.git"
   },
   "license": "MIT",
   "keywords": [
      "auth",
      "authentication",
      "jwt",
      "oauth",
      "authio"
   ],
   "publishConfig": {
      "access": "public"
   },
   "description": " A Prisma adapter for Authio",
   "private": false,
   "type": "module",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test": "vitest run",
      "typecheck": "tsc --noEmit"
   },
   "files": [
      "dist"
   ],
   "dependencies": {
      "nanoid": "^5.1.11"
   },
   "devDependencies": {
      "@prisma/adapter-pg": "^7.8.0",
      "@prisma/client": "^7.8.0",
      "@types/node": "^25.5.0",
      "@types/pg": "^8.20.0",
      "pg": "^8.20.0",
      "prisma": "^7.8.0",
      "@authio/core": "workspace:*",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   },
   "peerDependencies": {
      "@authio/core": ">=0.1.0"
   },
   "packageManager": "pnpm@10.33.0"
}
