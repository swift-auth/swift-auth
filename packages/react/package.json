{
   "name": "@authio/react",
   "private": false,
   "description": "A react library for authio",
   "author": "Dipan Chakraborty",
   "repository": {
      "type": "git",
      "url": "https://github.com/dipan-ck/authio.git"
   },
   "keywords": [
      "auth",
      "authentication",
      "jwt",
      "oauth",
      "authio"
   ],
   "publishConfig": {
      "access": "public"
   },
   "version": "0.1.1",
   "type": "module",
   "license": "MIT",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "files": [
      "dist"
   ],
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch"
   },
   "devDependencies": {
      "@types/node": "^25.5.0",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2"
   }
}
