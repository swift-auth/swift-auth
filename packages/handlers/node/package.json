{
   "name": "@authio/node",
   "version": "0.1.1",
   "author": "Dipan Chakraborty",
   "repository": {
      "type": "git",
      "url": "https://github.com/dipan-ck/authio.git"
   },
   "keywords": [
      "auth",
      "authentication",
      "jwt",
      "oauth",
      "authio"
   ],
   "description": "",
   "private": false,
   "publishConfig": {
      "access": "public"
   },
   "type": "module",
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "typecheck": "tsc --noEmit"
   },
   "files": [
      "dist"
   ],
   "license": "MIT",
   "packageManager": "pnpm@10.33.0",
   "devDependencies": {
      "@authio/core": "workspace:*",
      "@types/express": "^5.0.6",
      "@types/node": "^25.5.0",
      "express": "^5.2.1",
      "tsup": "^8.5.1",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   },
   "peerDependencies": {
      "@authio/core": ">=0.1.0",
      "express": "^5.0.0"
   }
}
